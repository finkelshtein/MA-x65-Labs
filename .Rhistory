ex <- gamma(1+1/beta) * alpha**(-1/beta)
r <- 1
seed <- 120
while (r>0.01) {
set.seed(seed)
x <- rweibull(10**6, shape=beta, scale=sigma)
m <- mean(x)
r <- abs(m-ex)
print(c(seed,r))
seed <- seed+1
}
c(seed,r)
